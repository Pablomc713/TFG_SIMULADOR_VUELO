<?xml version="1.0"?>

<turbine_engine name="F100-PW-200">

  <!-- ========================================================= -->
  <!-- PRÁCTICAS F16-P3 / F16-P6                                 -->
  <!-- P3: EMPUJE DISPONIBLE Y VUELO HORIZONTAL                  -->
  <!-- P6: MANIOBRA, VIRAJES Y ENERGÍA DISPONIBLE                -->
  <!-- Archivo: Engines/F100-PW-200.xml                          -->
  <!-- Variables estudiadas: milthrust, maxthrust, MilThrust,    -->
  <!-- AugThrust                                                 -->
  <!-- Fenómenos:                                                -->
  <!--   - equilibrio entre empuje y resistencia en vuelo        -->
  <!--     horizontal                                            -->
  <!--   - influencia del empuje disponible sobre la capacidad   -->
  <!--     de sostener virajes y conservar energía               -->
  <!-- Ecuaciones asociadas:                                     -->
  <!--   T = D                                                   -->
  <!--   L = W                                                   -->
  <!--   D = 1/2 * rho * V^2 * S * CD                            -->
  <!--   n = L / W                                               -->
  <!--   R = V^2 / (g * sqrt(n^2 - 1))                           -->
  <!--   omega = g * sqrt(n^2 - 1) / V                           -->
  <!-- Objetivo docente: modificar el empuje disponible para     -->
  <!-- analizar cambios en aceleración, velocidad máxima,        -->
  <!-- capacidad de sostener vuelo horizontal, pérdida de        -->
  <!-- velocidad en viraje y recuperación de energía             -->
  <!-- ========================================================= -->

  <!--
      Empuje nominal en régimen militar.

      Práctica F16-P3:
      permite estudiar la condición de vuelo horizontal, donde el empuje
      disponible debe equilibrar la resistencia aerodinámica.

      Práctica F16-P6:
      permite analizar la capacidad del avión para sostener virajes sin
      perder velocidad de forma excesiva. 

      Interpretación:
      este valor representa el empuje máximo disponible sin postcombustión.
      Aumentarlo mejora la aceleración y la capacidad de mantener velocidad
      sin emplear afterburner. Reducirlo limita las prestaciones del avión
      en vuelo horizontal y maniobra.

      Modificación docente:
      comparar el comportamiento del F-16 con valores inferiores y superiores
      al original permite visualizar la relación directa entre empuje
      disponible y prestaciones.
  -->

  <milthrust>   14670.0 </milthrust>

  <!--
      Empuje máximo con postcombustión.

      Práctica F16-P3:
      permite comparar el vuelo con potencia militar frente al vuelo con
      postcombustión, observando diferencias en aceleración y velocidad
      máxima.

      Práctica F16-P6:
      permite estudiar la recuperación de energía tras maniobras agresivas
      y la capacidad para sostener virajes exigentes.

      Interpretación:
      aumentar este valor mejora la aceleración y la recuperación de energía.
      Reducirlo hace más evidente la pérdida de velocidad durante maniobras.

      Modificación docente:
      aumentar o reducir este valor permite observar cambios en aceleración,
      velocidad máxima y capacidad para atravesar el régimen transónico.
  -->

  <maxthrust>   23830.0 </maxthrust>
  <bypassratio>     0.71 </bypassratio>
  <tsfc>            0.72 </tsfc>
  <atsfc>           2.1 </atsfc>
  <n1spinup>        0.5 </n1spinup>
  <n2spinup>        1.0 </n2spinup>
  <n1startrate>     1.2 </n1startrate>
  <n2startrate>     1.6 </n2startrate>
  <ignitionn1>      5.21</ignitionn1>
  <ignitionn2>     20.00</ignitionn2>
  <idlen1>         30.0 </idlen1>
  <idlen2>         60.0 </idlen2>
  <maxn1>         100.0 </maxn1>
  <maxn2>         100.0 </maxn2>
  <augmented>         1 </augmented>
  <augmethod>         2 </augmethod>
  <injected>          0 </injected>

  <!--
      The engine used for YF-16 and block 10.

      Sources:
              TP-1538
              Turbofan and Turbojet Engines: Database Handbook by Elodie Roux
              AeromatiC++
  -->

  <function name="IdleThrust">
    <product>
     <v>0.00006816632583503749</v>
     <table>
      <independentVar lookup="row">velocities/mach</independentVar>
      <independentVar lookup="column">atmosphere/density-altitude</independentVar>
      <tableData>
               0 10000 20000 30000 40000 50000 60000
       0.0   716   775  1018  1319  1735  2152     0 <!-- this row is from AeromatiC++ -->
       0.2   635   425   690  1010  1330  1700     0
       0.4    60    25   345   755  1130  1525     0
       0.6 -1020  -710  -300   350   910  1360     0
       0.8 -2700 -1900 -1300  -247   600  1100     0
       1.0 -3600 -1400  -595  -342  -200   700     0
      </tableData>
     </table>
    </product>
  </function>

  <!-- ========================================================= -->
  <!-- Tabla de empuje en régimen militar                        -->
  <!-- ========================================================= -->


  <function name="MilThrust">
    <product>
     <v>0.00006816632583503749</v>

     <!--
         Tabla de empuje militar en función del número de Mach
         y de la altitud de densidad.

         Filas:
         - velocities/mach

         Columnas:
         - atmosphere/density-altitude

         Práctica F16-P3:
         permite analizar cómo varía la velocidad alcanzable y la aceleración
         en vuelo horizontal al modificar el empuje disponible.

         Práctica F16-P6:
         permite estudiar cómo la disponibilidad de empuje afecta a la pérdida
         de velocidad durante virajes sostenidos y a la conservación de energía.

         Interpretación:
         cada valor de la tabla representa el empuje disponible sin
         postcombustión para una combinación de Mach y altitud.

         Modificación docente:
         modificar filas o columnas concretas permite estudiar cómo cambia
         el comportamiento del avión a baja, media o alta altitud, y cómo
         varía la capacidad de aceleración en función del Mach.
     -->

   <table>
    <independentVar lookup="row">velocities/mach</independentVar>
    <independentVar lookup="column">atmosphere/density-altitude</independentVar>
    <tableData>
             0   10000 20000 30000 40000 50000 60000
     0.0   14670 10856  7834  5457  3535  2186     0 <!-- this row is from AeromatiC++ -->
     0.2   12680  9150  6313  4040  2470  1400     0
     0.4   12610  9312  6610  4290  2600  1560     0
     0.6   12640  9839  7090  4660  2840  1660     0
     0.8   12390 10176  7750  5320  3250  1930     0
     1.0   11680  9848  8050  6100  3800  2310     0
     1.2   16353 12962  9891  7245  4840  2991     0 <!-- this row is from AeromatiC++ -->
     1.4   17509 14190 11041  8205  5539  3435     0 <!-- this row is from AeromatiC++ -->
    </tableData>
   </table>
   </product>
  </function>

  <!-- ========================================================= -->
  <!-- Tabla de empuje con postcombustión                        -->
  <!-- ========================================================= -->

  <function name="AugThrust">
    <product>
     <v>0.0000419639110365086</v>

     <!--
         Lógica de activación/ajuste de postcombustión.

         Interpretación:
         el empuje aumentado depende de condiciones del sistema eléctrico,
         del número de Mach y de la posición de gases. En este caso, la lógica
         comprueba que el motor esté alimentado, que el avión se encuentre en
         una condición de Mach determinada y que el mando de gases esté próximo
         al máximo.

         Para la práctica no es necesario modificar este bloque salvo que se
         quiera estudiar específicamente la lógica de activación del afterburner.
     -->

	 <ifthen>
		<and>
			<ge>
				<property>elec/bus/nacelle-noness-dc-1</property>
				<v>25</v>
			</ge>
			<ge>
				<property>velocities/mach</property>
				<v>1.1</v>
			</ge>
			<ge>
				<property>/controls/engines/engine[0]/throttle</property>
				<v>0.99</v>
			</ge>
		</and>
		 <sum>	
			<v>0.97</v>
			<product>
				<property>/f16/engine/max-power</property>
				<v>0.03</v>
			</product>
		 </sum>
		 <v>0.97</v>
	 </ifthen>

   <!--
        Tabla de empuje con postcombustión en función del número de Mach
        y de la altitud de densidad.

        Filas:
        - velocities/mach

        Columnas:
        - atmosphere/density-altitude

         Práctica F16-P3:
         permite estudiar la diferencia entre régimen militar y régimen
         aumentado en vuelo horizontal.

         Práctica F16-P6:
         permite analizar la capacidad de recuperar energía tras maniobras
         agresivas y de sostener virajes de alto factor de carga.

        Interpretación:
        estos valores representan el empuje disponible en régimen aumentado.
        Al compararlos con la tabla MilThrust se observa la ganancia de
        prestaciones que proporciona la postcombustión.

        Modificación docente:
        modificar esta tabla permite estudiar cómo cambia la aceleración,
        la velocidad máxima y la capacidad de sostener maniobras exigentes
        cuando se altera el empuje máximo disponible.
    -->

   <table>
    <independentVar lookup="row">velocities/mach</independentVar>
    <independentVar lookup="column">atmosphere/density-altitude</independentVar>
    <tableData>
                0 10000 20000 30000 40000 50000 60000
     0.0    23830 19502 15792 12582  8950  5545     0 <!-- this row is from AeromatiC++ -->
     0.2    21420 15700 11225  7323  4435  2600     0
     0.4    22700 16860 12250  8154  5000  2835     0
     0.6    24240 18910 13760  9285  5700  3215     0
     0.8    26070 21075 15975 11115  6860  3950     0
     1.0    28886 23319 18300 13484  8642  5057     0
     1.4    28951 23670 19114 15155 10744  6658     0 <!-- this row is from AeromatiC++ -->
     2.0    37413 31184 24959 19578 13788  8543     0 <!-- this row is from AeromatiC++ -->
    </tableData>
   </table>
   </product>
  </function>

</turbine_engine>
